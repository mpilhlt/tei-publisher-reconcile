{
  "$schema": "http://json-schema.org/schema#",
  "$id": "https://reconciliation-api.github.io/specs/draft/schemas/suggest-properties-response.json",
  "type": "object",
  "description": "This schema can be used to validate the JSON response of a suggest service for properties.",
  "properties": {
    "result": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Identifier of the suggested property"
          },
          "name": {
            "type": "string",
            "description": "Name of the suggested property"
          },
          "description": {
            "type": "string",
            "description": "An optional description which can be provided to disambiguate namesakes, providing more context."
          },
          "lang": {
            "type": "string",
            "description": "The text-processing language for the natural language fields of this object"
          },
          "dir": {
            "type": "string",
            "enum": [
              "ltr",
              "rtl",
              "auto"
            ],
            "description": "The text direction for the natural language fields of this object"
          },
          "matchQualifiers": {
            "type": "array",
            "description": "An optional array of objects representing the matchQualifiers supported for the suggested property",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Identifier of the matchQualifier"
                },
                "name": {
                  "type": "string",
                  "description": "Name of the matchQualifier"
                },
                "lang": {
                  "type": "string",
                  "description": "The text-processing language for the natural language fields of this object"
                },
                "dir": {
                  "type": "string",
                  "enum": [
                    "ltr",
                    "rtl",
                    "auto"
                  ],
                  "description": "The text direction for the natural language fields of this object"
                }
              },
              "required": [
                "id",
                "name"
              ]
            }
          }
        },
        "required": [
          "id",
          "name"
        ]
      }
    }
  },
  "required": [
    "result"
  ],
  "$defs": {
    "type": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Identifier of the suggested type"
        },
        "name": {
          "type": "string",
          "description": "Name of the suggested type"
        },
        "description": {
          "type": "string",
          "description": "An optional description which can be provided to disambiguate namesakes, providing more context."
        },
        "lang": {
          "type": "string",
          "description": "The text-processing language for the natural language fields of this object"
        },
        "dir": {
          "type": "string",
          "enum": [
            "ltr",
            "rtl",
            "auto"
          ],
          "description": "The text direction for the natural language fields of this object"
        },
        "broader": {
          "type": "array",
          "description": "An optional array of types, each representing a direct (i.e., immediate) broader category of entities.",
          "items": {
            "$ref": "#/$defs/type"
          }
        }
      },
      "required": [
        "id",
        "name"
      ]
    }
  }
}